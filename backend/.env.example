# ──────────────────────────────────────────────────────────────────────────────
# AI Provider — pick ONE: ollama | groq | openai | anthropic
# ──────────────────────────────────────────────────────────────────────────────
AI_PROVIDER=openai

# ──────────────────────────────────────────────────────────────────────────────
# Ollama  (free, local, fully private — no key needed)
# ──────────────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi:latest
# Other good models: llama3.2, mistral, gemma2

# ──────────────────────────────────────────────────────────────────────────────
# Groq  (FREE API — great for production, get key at https://console.groq.com)
# ──────────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192
# Other Groq models: llama3-70b-8192, mixtral-8x7b-32768

# ──────────────────────────────────────────────────────────────────────────────
# OpenAI  (cheap + reliable — ~$0.01 per resume on gpt-4o-mini)
# Get key at https://platform.openai.com/api-keys
# ──────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ──────────────────────────────────────────────────────────────────────────────
# Anthropic Claude  (high quality — ~$0.01 per resume on Haiku)
# Get key at https://console.anthropic.com
# ──────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ──────────────────────────────────────────────────────────────────────────────
# App settings
# ──────────────────────────────────────────────────────────────────────────────
PORT=8000

# Comma-separated list of allowed frontend origins. Add your production URL here
# after deploying the frontend. e.g. https://ics-resume-analyzer.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:4173

MAX_RESUME_CHARS=5000
MAX_JD_CHARS=3000
